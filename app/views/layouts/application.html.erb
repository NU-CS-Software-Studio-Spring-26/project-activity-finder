<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
  <head>
    <title><%= content_for(:title) || "Activity Finder" %></title>
    <%# Allow pinch-zoom; viewport-fit=cover for notched phones in installed PWA mode. %>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Activities">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Activity Finder">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0b1220">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon-192.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-body app-shell">
    <a class="visually-hidden-focusable app-skip-link" href="#main">Skip to main content</a>

    <nav class="navbar navbar-expand-lg app-navbar border-bottom">
      <div class="container-xxl">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2", "aria-label": "Activity Finder — home" do %>
          <span class="app-mark" aria-hidden="true"></span>
          <span class="navbar-brand-text">Activity Finder</span>
        <% end %>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNav" aria-controls="topNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="topNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <%= link_to "Activities", activities_path, class: "nav-link", "aria-label": "Browse all activities" %>
            </li>
          </ul>

          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <% if logged_in? %>
              <li class="nav-item">
                <%= link_to current_user.name, current_user, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-outline-secondary btn-sm ms-lg-2", form: { class: "d-inline" } %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Login", login_path, class: "nav-link", "aria-label": "Log in to your account" %>
              </li>
              <li class="nav-item">
                <%= link_to "Sign up", signup_path, class: "btn btn-primary btn-sm ms-lg-2", "aria-label": "Create a new account" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="app-gradient" aria-hidden="true"></div>

    <div class="container-xxl app-page-wrap my-3 my-lg-5">
      <div class="flash-stack" aria-live="polite" aria-atomic="true">
        <% if notice.present? %>
          <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="d-flex align-items-start gap-2">
              <div class="flex-grow-1"><%= notice %></div>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="d-flex align-items-start gap-2">
              <div class="flex-grow-1"><%= alert %></div>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          </div>
        <% end %>
      </div>

      <main id="main" class="app-main">
        <%= yield %>
      </main>

      <footer class="app-footer mt-5 pt-4 border-top">
        <div class="app-footer-links">
          <%= link_to "About Us", about_path %>
          <%= link_to "Terms of Service", terms_path %>
          <%= link_to "Privacy Policy", privacy_path %>
          <%= link_to "GitHub", "https://github.com/mzzhong/project-avtivity-finder", target: "_blank", rel: "noopener noreferrer" %>
        </div>

        <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 mt-3">
          <small class="app-footer-note">&copy; <%= Time.current.year %> Activity Finder</small>
          <small class="app-footer-note">Built with <abbr title="Ruby on Rails">Rails</abbr> &middot; Turbo &middot; Bootstrap</small>
        </div>
      </footer>
    </div>

    <%= render "layouts/mobile_bottom_nav" %>

    <% if logged_in? %>
      <%= render "advisor/chat_widget" %>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
