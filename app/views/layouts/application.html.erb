<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
  <head>
    <title><%= content_for(:title) || "Open Scene" %></title>
    <%# Allow pinch-zoom; viewport-fit=cover for notched phones in installed PWA mode. %>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Activities">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Open Scene">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0b1220">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "logo2.png", type: "image/png" %>
    <%= favicon_link_tag "logo2.png", rel: "apple-touch-icon" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-body app-shell">
    <a class="visually-hidden-focusable app-skip-link" href="#main">Skip to main content</a>

    <nav class="navbar navbar-expand-lg app-navbar">
      <div class="container-xxl app-navbar-inner">
        <%= link_to root_path, class: "app-navbar-brand", "aria-label": "Open Scene — home" do %>
          <%= image_tag "logo2.png", height: 32, alt: "Open Scene logo" %>
          <span class="app-navbar-brand-text">Open Scene</span>
        <% end %>

        <div class="app-navbar-actions">
          <% if logged_in? %>
            <%= link_to current_user, class: "app-nav-avatar-link", "aria-label": "Your profile (#{current_user.name})" do %>
              <%= render "users/avatar", user: current_user, size: :sm %>
            <% end %>
            <%= button_to logout_path,
                  method: :delete,
                  class: "app-nav-signout-btn",
                  form: { class: "d-inline" },
                  title: "Log out",
                  "aria-label": "Log out" do %>
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H9m4 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1" />
              </svg>
            <% end %>
          <% else %>
            <button class="navbar-toggler app-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#guestNav" aria-controls="guestNav" aria-expanded="false" aria-label="Toggle navigation">
              <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="guestNav">
              <div class="app-navbar-guest-actions">
                <%= link_to "Log in", login_path, class: "app-nav-text-btn" %>
                <%= link_to "Sign up", signup_path, class: "app-nav-pill-btn" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container-xxl app-page-wrap my-3 my-lg-5">
      <div class="flash-stack" aria-live="polite" aria-atomic="true" data-controller="flash" data-flash-delay-value="3000">
        <% if notice.present? %>
          <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="d-flex align-items-start gap-2">
              <div class="flex-grow-1"><%= notice %></div>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="d-flex align-items-start gap-2">
              <div class="flex-grow-1"><%= alert %></div>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          </div>
        <% end %>
      </div>

      <main id="main" class="app-main">
        <%= yield %>
      </main>

      <footer class="app-footer mt-5 pt-4 border-top">
        <div class="app-footer-links">
          <%= link_to "About Us", about_path %>
          <%= link_to "Terms of Service", terms_path %>
          <%= link_to "Community Guidelines", guidelines_path %>
          <%= link_to "Privacy Policy", privacy_path %>
          <%= link_to "GitHub", "https://github.com/mzzhong/project-avtivity-finder", target: "_blank", rel: "noopener noreferrer" %>
        </div>

        <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 mt-3">
          <small class="app-footer-note">&copy; <%= Time.current.year %> Open Scene</small>
          <small class="app-footer-note">Built with <abbr title="Ruby on Rails">Rails</abbr> &middot; Turbo &middot; Bootstrap</small>
        </div>
      </footer>
    </div>

    <%= render "layouts/mobile_bottom_nav" %>

    <% if logged_in? %>
      <%= render "advisor/chat_widget" %>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
