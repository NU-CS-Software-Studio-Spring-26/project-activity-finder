<% content_for :title, "Choose a new password" %>

<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title mb-1" id="auth-heading">Choose a new password</h1>
    <p class="text-muted text-center mb-4" id="auth-intro">
      Must be at least 5 characters.
    </p>

    <%= form_with url: edit_password_reset_path(@token),
          method: :patch,
          html: { "aria-labelledby": "auth-heading", "aria-describedby": "auth-intro" } do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= label_tag "user[password]", "New password", class: "form-label" %>
        <%= password_field_tag "user[password]", nil,
              class: "form-control",
              autocomplete: "new-password",
              autofocus: true,
              minlength: 5,
              required: true %>
      </div>

      <div class="mb-3">
        <%= label_tag "user[password_confirmation]", "Confirm new password", class: "form-label" %>
        <%= password_field_tag "user[password_confirmation]", nil,
              class: "form-control",
              autocomplete: "new-password",
              required: true %>
      </div>

      <%= submit_tag "Update password", class: "btn btn-primary btn-auth" %>
    <% end %>
  </div>
</div>
