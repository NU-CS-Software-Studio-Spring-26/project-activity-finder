<% content_for :title, "Activity unavailable" %>

<div class="activity-unavailable-page mx-auto" style="max-width: 36rem;">
  <div class="activity-info-card text-center py-5 px-4">
    <div class="mb-3" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
      </svg>
    </div>

    <h1 class="h3 mb-3">Activity unavailable</h1>
    <p class="text-muted mb-4"><%= activity_unavailable_message %></p>

    <%= link_to "Browse activities", activities_path, class: "btn btn-primary" %>
  </div>
</div>
