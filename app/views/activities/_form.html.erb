<%= form_with(model: activity) do |form| %>
  <% if params[:from] == "profile" %>
    <%= hidden_field_tag :from, "profile" %>
    <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>
  <% end %>

  <% if activity.errors.any? %>
    <div class="alert alert-danger">
      <h2 class="h5"><%= pluralize(activity.errors.count, "error") %> prohibited this activity from being saved:</h2>
      <ul>
        <% activity.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, "Title *", class: "form-label" %>
    <%= form.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.textarea :description, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :location, class: "form-label" %>
    <%= form.text_field :location, class: "form-control" %>
  </div>

  <div
    class="mb-3"
    data-controller="city-field"
    data-city-field-popular-cities-value='<%= ActivitiesHelper::POPULAR_ACTIVITY_CITIES.to_json %>'
    data-city-field-max-length-value="100"
  >
    <%= form.label :city, "City *", class: "form-label" %>
    <%= form.text_field :city,
          class: "form-control",
          required: true,
          list: "activity-city-suggestions",
          autocomplete: "address-level2",
          data: { city_field_target: "input" } %>
    <datalist id="activity-city-suggestions">
      <% ActivitiesHelper::POPULAR_ACTIVITY_CITIES.each do |city| %>
        <option value="<%= city %>"></option>
      <% end %>
    </datalist>
    <div class="form-text d-none" data-city-field-target="hint"></div>
    <div class="invalid-feedback d-none" data-city-field-target="feedback"></div>
  </div>

  <div class="mb-3">
    <%= form.label :category, "Category *", class: "form-label" %>
    <%= form.text_field :category, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :event_date, "Event Date *", class: "form-label" %>
    <%= form.date_field :event_date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :capacity, "Capacity (optional)", class: "form-label" %>
    <%= form.number_field :capacity, class: "form-control", min: 1, step: 1 %>
    <div class="form-text">Maximum attendees (not including the host). Leave blank for no limit.</div>
  </div>

  <div class="mb-3 image-upload-area">
    <%= form.label :images, "Activity Images", class: "form-label" %>

    <% if activity.persisted? && activity.images.attached? %>
      <p class="text-muted mb-2">
        Drag images to reorder. The first image becomes the homepage thumbnail.
      </p>
      <div id="existing-image-list" class="image-preview-list mb-3">
        <% activity.ordered_images.each do |image| %>
          <div class="image-preview-item existing-image-item" draggable="true" data-id="<%= image.id %>">
            <%= hidden_field_tag "activity[image_order][]", image.id, class: "image-order-input" %>
            <div class="thumbnail-badge">Drag</div>
            <%= image_tag image.variant(resize_to_fill: [300, 180]), class: "existing-image-preview", alt: activity.title.presence || "Activity image" %>
            <div class="form-check mt-2">
              <%= check_box_tag "activity[remove_image_ids][]", image.id, false, class: "form-check-input" %>
              <%= label_tag "remove_image_#{image.id}", "Delete image", class: "form-check-label text-danger" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div id="drop-zone" class="drop-zone">
      <p class="mb-1">Drag images here or click to upload</p>
      <small class="text-muted">Up to 10 images. Drag previews to reorder. First image becomes thumbnail.</small>
    </div>

    <%= form.file_field :images,
          multiple: true,
          accept: "image/*",
          class: "d-none",
          id: "activity-images-input" %>

    <div id="image-preview-list" class="image-preview-list mt-3"></div>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
