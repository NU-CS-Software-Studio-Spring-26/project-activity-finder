<%= form_with(model: activity,
              html: {
                data: {
                  controller: "category-picker",
                  category_picker_presets_value: Activity::CATEGORIES,
                  action: "submit->category-picker#beforeSubmit"
                }
              }) do |form| %>
  <% if params[:from] == "profile" %>
    <%= hidden_field_tag :from, "profile" %>
    <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>
  <% end %>

  <% if activity.errors.any? %>
    <div class="alert alert-danger">
      <h2 class="h5"><%= pluralize(activity.errors.count, "error") %> prohibited this activity from being saved:</h2>
      <ul>
        <% activity.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, "Title *", class: "form-label" %>
    <%= form.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.textarea :description, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :location, class: "form-label" %>
    <%= form.text_field :location, class: "form-control" %>
  </div>

  <div
    class="mb-3 city-picker-field"
    data-controller="city-picker"
    data-city-picker-popular-cities-value='<%= raw Activity.allowed_cities.to_json %>'
    data-city-picker-initial-city-value="<%= h(activity.city.to_s) %>"
    data-city-picker-mode-value="field"
    data-city-picker-required-value="true"
    data-city-picker-empty-label-value="Select a city"
  >
    <%= form.label :city, "City *", class: "form-label" %>
    <%= form.hidden_field :city, data: { city_picker_target: "cityInput" } %>
    <%= render "shared/city_picker_menu",
          id_prefix: "activity-city",
          aria_label: "Select city",
          go_button_title: "Apply city",
          dropdown_class: "city-picker-dropdown-field w-100" %>
    <div id="activity-city-help" class="form-text">Search or pick a supported US city from the list.</div>
  </div>

  <div class="mb-3">
    <%= form.label :category, "Category *", class: "form-label" %>

    <select class="form-select mb-2"
            data-category-picker-target="select"
            data-custom-value="<%= Activity::CUSTOM_CATEGORY %>"
            data-action="change->category-picker#toggle"
            required
            aria-describedby="category-help">
      <option value="" disabled <%= activity.category.blank? ? "selected" : "" %>>Select a category</option>
      <% Activity.category_options.each do |category_name| %>
        <option value="<%= category_name %>" <%= "selected" if activity.category == category_name %>><%= category_name %></option>
      <% end %>
      <option value="<%= Activity::CUSTOM_CATEGORY %>"
              <%= "selected" if activity.category.present? && !activity.preset_category? %>>
        Other (add your own)
      </option>
    </select>

    <div class="<%= activity.preset_category? || activity.category.blank? ? "d-none" : "" %>"
         data-category-picker-target="customWrap">
      <%= label_tag nil, "Custom category *", class: "form-label" %>
      <%= text_field_tag nil,
            activity.preset_category? ? nil : activity.category,
            class: "form-control",
            placeholder: "e.g. Book club, beach cleanup…",
            data: { category_picker_target: "custom", action: "input->category-picker#sync" } %>
    </div>

    <%= form.hidden_field :category, data: { category_picker_target: "output" } %>
    <div id="category-help" class="form-text">Pick a common category or choose Other to type your own.</div>
  </div>

  <div class="mb-3">
    <%= form.label :event_date, "Event Date *", class: "form-label" %>
    <%= form.date_field :event_date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :capacity, "Capacity (optional)", class: "form-label" %>
    <%= form.number_field :capacity, class: "form-control", min: 1, step: 1 %>
    <div class="form-text">Maximum attendees (not including the host). Leave blank for no limit.</div>
  </div>

  <div class="mb-3">
    <%= form.label :visibility, "Visibility", class: "form-label d-block" %>
    <div class="btn-group" role="group" aria-label="Activity visibility">
      <% Activity::VISIBILITY_OPTIONS.each do |option| %>
        <%= form.radio_button :visibility, option,
              class: "btn-check",
              id: "activity_visibility_#{option}" %>
        <%= form.label :visibility, class: "btn btn-outline-secondary",
              for: "activity_visibility_#{option}" do %>
          <% if option == "public" %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
            </svg>
            Public
          <% else %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
            </svg>
            Private
          <% end %>
        <% end %>
      <% end %>
    </div>
    <div class="form-text">
      <strong>Public</strong> activities appear in the browse list for everyone.
      <strong>Private</strong> activities are invite-only — share the link to let people join.
    </div>
  </div>

  <div class="mb-3 image-upload-area">
    <%= form.label :images, "Activity Images", class: "form-label" %>

    <% if activity.persisted? && activity.images.attached? %>
      <p class="text-muted mb-2">
        Drag images to reorder. The first image becomes the homepage thumbnail.
      </p>
      <div id="existing-image-list" class="image-preview-list mb-3">
        <% activity.ordered_images.each do |image| %>
          <div class="image-preview-item existing-image-item" draggable="true" data-id="<%= image.id %>">
            <%= hidden_field_tag "activity[image_order][]", image.id, class: "image-order-input" %>
            <div class="thumbnail-badge">Drag</div>
            <%= image_tag image.variant(resize_to_fill: [300, 180]), class: "existing-image-preview", alt: activity.title.presence || "Activity image" %>
            <div class="form-check mt-2">
              <%= check_box_tag "activity[remove_image_ids][]", image.id, false, class: "form-check-input" %>
              <%= label_tag "remove_image_#{image.id}", "Delete image", class: "form-check-label text-danger" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div id="drop-zone" class="drop-zone">
      <p class="mb-1">Drag images here or click to upload</p>
      <small class="text-muted">Up to 10 images. Drag previews to reorder. First image becomes thumbnail.</small>
    </div>

    <%= form.file_field :images,
          multiple: true,
          accept: "image/*",
          class: "d-none",
          id: "activity-images-input" %>

    <div id="image-preview-list" class="image-preview-list mt-3"></div>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
