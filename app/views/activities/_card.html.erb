<%# locals: (activity:, show_host: false, show_delete: false, return_to: nil) %>
<% show_host = local_assigns.fetch(:show_host, false) %>
<% show_delete = local_assigns.fetch(:show_delete, false) %>
<% return_to = local_assigns[:return_to] %>
<% link_params = activity_link_params(return_to: return_to) %>
<div class="activity-card">
  <div class="activity-card-img">
    <%= link_to activity_path(activity, **link_params) do %>
      <%= image_tag activity_image(activity), class: "img-fluid", alt: activity_image_alt(activity) %>
    <% end %>
  </div>

  <div class="activity-card-body">
    <% if activity.private? %>
      <span class="badge text-bg-secondary d-inline-flex align-items-center gap-1 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
        </svg>
        Private
      </span>
    <% end %>
    <h2 class="activity-title h5 mb-1">
      <%= link_to activity.title, activity_path(activity, **link_params) %>
    </h2>

    <div class="activity-meta-list mb-2">
      <% if activity.city.present? %>
        <span class="activity-meta-item">
          <svg class="activity-meta-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
          <%= activity.city %>
        </span>
      <% end %>
      <% if activity.event_date.present? %>
        <span class="activity-meta-item">
          <svg class="activity-meta-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 2v2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-2V2h-2v2H9V2H7zm12 7v10H5V9h14z"/></svg>
          <%= activity.event_date.strftime("%b %d, %Y") %>
        </span>
      <% end %>
    </div>

    <% if show_host && activity.user.present? %>
      <p class="activity-meta small mb-2">Hosted by <%= activity.user.name %></p>
    <% end %>

    <span class="activity-chip mt-auto"><%= activity.category %></span>

    <% if show_delete %>
      <div class="activity-card-actions mt-2">
        <%= button_to "Delete",
              activity_path(activity),
              method: :delete,
              class: "btn btn-sm btn-danger",
              params: { from: "profile", return_to: return_to },
              form: { data: { turbo_confirm: "Delete this activity? This cannot be undone." } } %>
      </div>
    <% end %>
  </div>
</div>
