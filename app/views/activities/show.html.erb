<% content_for :title, @activity.title %>

<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<% end %>

<div class="activity-detail-page">
  <div class="activity-detail-actions mb-4 d-flex flex-wrap gap-2">
    <%= link_to(@from_profile ? "Back to profile" : "Back to Activities", @return_to, class: "btn btn-outline-secondary") %>
    <% if current_user.admin? || @activity.user == current_user || @joined %>
      <%= link_to "Download PDF report",
            export_pdf_activity_path(@activity),
            class: "btn btn-outline-primary" %>
    <% end %>
    <% if @show_manage_actions %>
      <%= link_to "Edit Activity",
            edit_activity_path(@activity, from: "profile", return_to: params[:return_to]),
            class: "btn btn-activity-edit" %>
      <%= button_to "Delete Activity",
            @activity,
            method: :delete,
            class: "btn btn-danger",
            form: {
              data: { turbo_confirm: "Are you sure?" },
              params: { from: "profile", return_to: params[:return_to] }
            } %>
    <% end %>
  </div>

  <div class="activity-hero-card mb-4">
    <% if @activity.images.attached? %>
      <div id="activityImagesCarousel" class="carousel slide">
        <div class="carousel-inner">
          <% @activity.ordered_images.each_with_index do |image, index| %>
            <div class="carousel-item <%= "active" if index == 0 %>">
              <%= image_tag image, class: "activity-carousel-image", alt: @activity.title %>
            </div>
          <% end %>
        </div>

        <% if @activity.images.count > 1 %>
          <button class="carousel-control-prev" type="button" data-bs-target="#activityImagesCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>

          <button class="carousel-control-next" type="button" data-bs-target="#activityImagesCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        <% end %>
      </div>
    <% else %>
      <%= image_tag activity_image(@activity), class: "activity-carousel-image", alt: activity_image_alt(@activity) %>
    <% end %>
  </div>

  <div class="activity-detail-content">
    <main class="activity-main-info">
      <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
        <span class="activity-category-badge"><%= @activity.category %></span>
        <% if @activity.private? %>
          <span class="badge text-bg-secondary d-inline-flex align-items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
            </svg>
            Private
          </span>
        <% end %>
      </div>
      <h1 class="activity-detail-title mt-2"><%= @activity.title %></h1>

      <% if @activity.description.present? %>
        <section class="activity-section">
          <h2>About this activity</h2>
          <%= simple_format(@activity.description) %>
        </section>
      <% end %>

      <section class="activity-section">
        <h2>Location map</h2>
        <% if activity_location_map_showable?(@activity) %>
          <% if @map_coordinates %>
            <div class="activity-map-panel"
                 data-controller="activity-map"
                 data-activity-map-lat-value="<%= @map_coordinates[:lat] %>"
                 data-activity-map-lon-value="<%= @map_coordinates[:lon] %>">
              <div class="activity-map-container" data-activity-map-target="map" role="region" aria-label="Map showing activity location"></div>
            </div>
          <% else %>
            <p class="activity-map-unavailable-text text-muted mb-0">
              Map view is not available for this location.
            </p>
          <% end %>
        <% else %>
          <p class="activity-map-unavailable-text text-muted mb-0">
            Map view is not available for this location.
          </p>
        <% end %>
      </section>
    </main>

    <aside class="activity-detail-sidebar">
      <div class="activity-info-card">
        <h2>Details</h2>

        <div class="activity-info-row">
          <span class="activity-info-label">Date</span>
          <span class="activity-info-value"><%= @activity.event_date&.strftime("%B %d, %Y") || "N/A" %></span>
        </div>

        <div class="activity-info-row">
          <span class="activity-info-label">City</span>
          <span class="activity-info-value"><%= @activity.city.presence || "N/A" %></span>
        </div>

        <div class="activity-info-row">
          <span class="activity-info-label">Location</span>
          <span class="activity-info-value"><%= @activity.location.presence || "N/A" %></span>
        </div>

        <div class="activity-info-row">
          <span class="activity-info-label">Category</span>
          <span class="activity-info-value"><%= @activity.category.presence || "N/A" %></span>
        </div>

        <div class="activity-info-row">
          <span class="activity-info-label">Host</span>
          <span class="activity-info-value"><%= @activity.user&.name.presence || "Unknown" %></span>
        </div>

        <div class="activity-info-row">
          <span class="activity-info-label">Spots</span>
          <span class="activity-info-value">
            <% if @activity.capacity.present? %>
              <%= @signup_count %>/<%= @activity.capacity %>
              <% if @full %>
                <span class="badge text-bg-warning ms-2">Full</span>
              <% end %>
            <% else %>
              <%= @signup_count %> going (no limit)
            <% end %>
          </span>
        </div>
      </div>

      <div class="activity-info-card mt-3">
        <h2>Attendees (<%= @attendees.size %>)</h2>

        <% if @attendees.any? %>
          <ul class="list-group list-group-flush activity-attendee-list">
            <% @attendees.each do |attendee| %>
              <li class="list-group-item px-0">
                <div class="d-flex justify-content-between align-items-center gap-2">
                  <div>
                    <div class="fw-semibold"><%= attendee.name %></div>
                    <div class="text-muted small"><%= attendee.email %></div>
                  </div>
                  <% if attendee == current_user %>
                    <span class="badge text-bg-secondary">You</span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No one has signed up yet.</p>
        <% end %>
      </div>

      <% if @activity.user_id != current_user.id %>
        <div class="activity-info-card mt-3">
          <h2>RSVP</h2>

          <% if @joined %>
            <%= button_to "Leave activity", leave_activity_path(@activity), method: :delete, class: "btn btn-outline-danger w-100", form: { data: { turbo_confirm: "Leave this activity?" } } %>
          <% elsif @full %>
            <button class="btn btn-secondary w-100" type="button" disabled>This activity is full</button>
          <% else %>
            <%= button_to "Join activity", join_activity_path(@activity), method: :post, class: "btn btn-primary w-100" %>
          <% end %>
        </div>
      <% else %>
        <div class="activity-info-card mt-3">
          <h2>RSVP</h2>
          <p class="text-muted mb-0">You're the host for this activity.</p>
        </div>
      <% end %>

      <% if @share_url.present? %>
        <div class="activity-info-card mt-3" data-controller="share-link">
          <h2>Share link</h2>
          <% if @activity.private? %>
            <p class="text-muted small mb-2">Anyone with this link can view and join your private activity.</p>
          <% else %>
            <p class="text-muted small mb-2">Share this link so others can find this activity directly.</p>
          <% end %>
          <div class="input-group input-group-sm">
            <input type="text"
                   class="form-control font-monospace"
                   value="<%= @share_url %>"
                   readonly
                   data-share-link-target="input"
                   aria-label="Shareable link">
            <button class="btn btn-outline-secondary"
                    type="button"
                    data-action="share-link#copy"
                    data-share-link-target="button">
              Copy
            </button>
          </div>
        </div>
      <% end %>
    </aside>
  </div>
</div>
