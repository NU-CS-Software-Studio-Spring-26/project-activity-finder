<% content_for :title, "About Us" %>

<%= render layout: "pages/page_card", locals: { title: "About Us" } do %>
  <section>
    <h2>What is Activity Finder?</h2>
    <p>
      Activity Finder is a community-driven platform that helps people discover and organize
      local activities and events. Whether it's a sunrise hike, a trivia night, or a weekend
      art walk, Activity Finder makes it easy to create an event, share it with others, and
      see who's coming.
    </p>
  </section>

  <section>
    <h2>Why We Built It</h2>
    <p>
      This project was built as part of CS 397 at Northwestern University. Our goal was to
      create a practical, production-quality web application that solves a real problem:
      making it easier for people to find things to do and connect with others in their community.
    </p>
  </section>

  <section>
    <h2>Technology</h2>
    <p>Activity Finder is built with:</p>
    <ul>
      <li>Ruby on Rails 8</li>
      <li>PostgreSQL</li>
      <li>Hotwire (Turbo)</li>
      <li>Bootstrap 5</li>
      <li>Active Storage for image uploads</li>
    </ul>
  </section>

  <section>
    <h2>Source Code</h2>
    <p>
      Activity Finder is open source. You can find the code on
      <%= link_to "GitHub", "https://github.com/NU-CS-Software-Studio-Spring-26/project-activity-finder/", target: "_blank", rel: "noopener noreferrer" %>.
    </p>
  </section>
<% end %>
