<%= form_with(model: user, html: { multipart: true }) do |form| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <div class="fw-semibold mb-1">
        <%= pluralize(user.errors.count, "error") %> prohibited this profile from being saved:
      </div>
      <ul class="mb-0">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="profile-form-avatar mb-4">
    <%= render "users/avatar", user: user, size: :lg, class_name: "profile-form-avatar-preview" %>
    <div class="profile-form-avatar-fields">
      <%= form.label :avatar, "Profile photo", class: "form-label" %>
      <%= form.file_field :avatar, class: "form-control", accept: "image/jpeg,image/png,image/webp,image/gif" %>
      <div class="form-text">JPEG, PNG, WebP, or GIF. Max 5 MB. Leave empty to keep your current photo.</div>
      <% if user.avatar.attached? %>
        <div class="form-check mt-2">
          <%= check_box_tag "user[remove_avatar]", "1", false, class: "form-check-input", id: "user_remove_avatar" %>
          <%= label_tag "user_remove_avatar", "Remove current photo", class: "form-check-label" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control", autocomplete: "name", maxlength: User::NAME_MAX_LENGTH %>
    </div>

    <div class="col-12 col-md-6">
      <%= form.label :password, class: "form-label" %>
      <%= form.password_field :password, class: "form-control", autocomplete: "new-password" %>
      <div class="form-text">Leave blank to keep your current password.</div>
    </div>

    <div class="col-12 col-md-6">
      <%= form.label :password_confirmation, class: "form-label" %>
      <%= form.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
    </div>

    <div class="col-12 d-flex flex-wrap gap-2 pt-2">
      <%= form.submit "Save changes", class: "btn btn-primary" %>
      <%= link_to "Cancel", user, class: "btn btn-outline-secondary" %>
    </div>
  </div>
<% end %>
