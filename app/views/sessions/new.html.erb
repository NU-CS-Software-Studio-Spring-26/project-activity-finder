<% content_for :title, "Login" %>

<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title mb-1" id="auth-heading">Welcome back</h1>
    <p class="text-muted text-center mb-4" id="auth-intro">Log in to create activities and RSVP.</p>

    <%= form_with url: login_path, method: :post, html: { "aria-labelledby": "auth-heading", "aria-describedby": "auth-intro" } do %>
      <div class="mb-3">
        <%= label_tag :email, "Email", class: "form-label" %>
        <%= email_field_tag :email, nil, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= label_tag :password, "Password", class: "form-label" %>
        <%= password_field_tag :password, nil, class: "form-control" %>
      </div>

      <%= submit_tag "Login", class: "btn btn-primary btn-auth" %>
    <% end %>

    <p class="text-muted text-center small mb-2 mt-3" id="google-auth-divider">or</p>
    <%= button_to google_oauth_authorize_path,
                  method: :post,
                  class: "btn btn-google-signin w-100 mb-2",
                  form: { class: "d-grid", data: { turbo: false } },
                  aria: { label: "Login with Google" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="18" height="18" style="margin-right: 8px; vertical-align: middle;">
          <path fill="#EA4335" d="M24 9.5c3.14 0 5.95 1.08 8.17 2.85l6.09-6.09C34.46 3.1 29.5 1 24 1 14.82 1 7.07 6.48 3.64 14.18l7.08 5.5C12.4 13.02 17.73 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.52 24.5c0-1.64-.15-3.22-.42-4.75H24v9h12.68c-.55 2.96-2.2 5.48-4.68 7.17l7.18 5.57C43.44 37.28 46.52 31.36 46.52 24.5z"/>
          <path fill="#FBBC05" d="M10.72 28.32A14.6 14.6 0 0 1 9.5 24c0-1.5.26-2.95.72-4.32l-7.08-5.5A23.94 23.94 0 0 0 0 24c0 3.87.93 7.53 2.58 10.76l8.14-6.44z"/>
          <path fill="#34A853" d="M24 47c5.5 0 10.12-1.82 13.5-4.95l-7.18-5.57C28.6 38.1 26.42 39 24 39c-6.27 0-11.6-3.52-13.28-8.68l-8.14 6.44C6.07 44.52 14.42 47 24 47z"/>
        </svg>
      Login with Google
    <% end %>
    <% unless google_oauth_configured? %>
      <p class="form-text text-center small mb-0" id="google-oauth-setup-hint">
        Add <code class="small">GOOGLE_CLIENT_ID</code> and <code class="small">GOOGLE_CLIENT_SECRET</code> to <code class="small">.env</code> (see <code class="small">.env.example</code>) for this button to work.
      </p>
    <% end %>

    <div class="auth-links">
      <span class="auth-links-prompt">Don't have an account?</span>
      <%= link_to "Sign up", signup_path, "aria-label": "Sign up for a new Activity Finder account" %> <br />
      <span class="auth-links-prompt">Forgot password?</span>
      <%= link_to "Reset it", forgot_password_path, "aria-label": "Reset your password" %>
    </div>
  </div>
</div>