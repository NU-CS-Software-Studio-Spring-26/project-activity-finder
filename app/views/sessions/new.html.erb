<% content_for :title, "Login" %>

<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title mb-1" id="auth-heading">Welcome back</h1>
    <p class="text-muted text-center mb-4" id="auth-intro">Log in to create activities and RSVP.</p>

    <%= form_with url: login_path, method: :post, html: { "aria-labelledby": "auth-heading", "aria-describedby": "auth-intro" } do %>
      <div class="mb-3">
        <%= label_tag :email, "Email", class: "form-label" %>
        <%= email_field_tag :email, nil, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= label_tag :password, "Password", class: "form-label" %>
        <%= password_field_tag :password, nil, class: "form-control" %>
      </div>

      <%= submit_tag "Login", class: "btn btn-primary btn-auth" %>
    <% end %>

    <p class="text-muted text-center small mb-2 mt-3" id="google-auth-divider">or</p>
    <%= button_to google_oauth_authorize_path,
                  method: :post,
                  class: "btn btn-google-signin w-100 mb-2",
                  form: { class: "d-grid", data: { turbo: false } },
                  aria: { label: "Sign in with Google" } do %>
      Sign in with Google
    <% end %>
    <% unless google_oauth_configured? %>
      <p class="form-text text-center small mb-0" id="google-oauth-setup-hint">
        Add <code class="small">GOOGLE_CLIENT_ID</code> and <code class="small">GOOGLE_CLIENT_SECRET</code> to <code class="small">.env</code> (see <code class="small">.env.example</code>) for this button to work.
      </p>
    <% end %>

    <div class="auth-links">
      <span class="auth-links-prompt">Don't have an account?</span>
      <%= link_to "Sign up", signup_path, "aria-label": "Sign up for a new Activity Finder account" %>
    </div>
  </div>
</div>